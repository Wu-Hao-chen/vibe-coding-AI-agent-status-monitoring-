# Copy to .env (gitignored) and fill in your own values, or export these as
# real environment variables however your process manager prefers (systemd
# EnvironmentFile=, pm2, docker-compose, etc.)

PORT=3456

# Must match CLS_COOKIE_KEY in php/config.php
CLS_COOKIE_KEY=REPLACE_ME_openssl_rand_hex_32

# Secret for the /admin/upload-html endpoint (deploy a new dashboard build
# remotely). Pick your own random string.
UPLOAD_SECRET=REPLACE_ME
